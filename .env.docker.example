# Скопируйте в .env перед docker compose up
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=

# DATABASE_URL задаётся в docker-compose.yml (PostgreSQL)
# DATABASE_URL=postgres://shopkg:shopkg@db:5432/shopkg

STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=

# Заполнить демо-данными при старте контейнера
SEED_DEMO=true
