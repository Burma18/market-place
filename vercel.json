{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "DATABASE_URL= python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
